# Server
NODE_ENV=production
PORT=3001

# Database
DB_HOST=postgres-service
DB_PORT=5432
DB_NAME=plutocloud
DB_USER=plutocloud
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# JWT
JWT_SECRET=CHANGE_ME_JWT_SECRET_MIN_64_CHARS
JWT_EXPIRES_IN=24h

# Paystack
PAYSTACK_PUBLIC_KEY=pk_live_REPLACE_WITH_YOUR_KEY
PAYSTACK_SECRET_KEY=sk_live_REPLACE_WITH_YOUR_KEY

# Zoho SMTP
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=eniola@plutocloudcomputing.ng
SMTP_PASS=REPLACE_WITH_ZOHO_PASSWORD
SMTP_FROM=Pluto Cloud Computing <eniola@plutocloudcomputing.ng>
FINANCE_EMAIL=tobe@plutocloudcomputing.ng
SUPPORT_EMAIL=info@plutocloudcomputing.ng
ADMIN_EMAIL=eniola@plutocloudcomputing.ng

# App
APP_URL=https://portal.plutocloudcomputing.ng
FRONTEND_URL=https://portal.plutocloudcomputing.ng

# Pricing (in kobo - multiply naira by 100)
PRICE_VCPU=2450000
PRICE_RAM_GB=262500
PRICE_STORAGE_GB=10800
PRICE_WINDOWS_OS=3000000
RESELLER_DISCOUNT=0.20
VAT_RATE=0.075

# Paystack fees
PAYSTACK_FEE_PERCENT=0.015
PAYSTACK_FEE_FLAT=10000
PAYSTACK_FEE_CAP=200000

# Withdrawals
MIN_WITHDRAWAL=1000000
